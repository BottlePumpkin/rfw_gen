widget productList = Column(
  children: [
    Container(
      padding: [16.0],
      color: 0xFF2196F3,
      child: Text(
        text: "상품 목록",
        style: {
          fontSize: 20.0,
          fontWeight: "bold",
          color: 0xFFFFFFFF
        }
      )
    ),
    Expanded(
      child: ListView(
        padding: [8.0],
        children: [
          ...for item in data.products.items:
            GestureDetector(
              onTap: event "navigate" { page: "productDetail" },
              child: Card(
                margin: [4.0],
                child: Padding(
                  padding: [12.0],
                  child: Row(
                    children: [
                      ClipRRect(
                        borderRadius: [
                          {
                            x: 8.0
                          }
                        ],
                        child: Image(
                          width: 80.0,
                          height: 80.0,
                          fit: "cover"
                        )
                      ),
                      SizedBox(
                        width: 12.0
                      ),
                      Expanded(
                        child: Column(
                          crossAxisAlignment: "start",
                          children: [
                            Text(
                              text: item.name,
                              style: {
                                fontSize: 16.0,
                                fontWeight: "bold"
                              }
                            ),
                            SizedBox(
                              height: 4.0
