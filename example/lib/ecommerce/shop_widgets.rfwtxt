                        )
                      )
                    ]
                  )
                )
              )
            )
        ]
      )
    )
  ]
);

widget productDetail { quantity: 0x00000001 } = SingleChildScrollView(
  child: Column(
    crossAxisAlignment: "start",
    children: [
      Image(
        width: 400.0,
        height: 300.0,
        fit: "cover"
      ),
      Padding(
        padding: [16.0],
        child: Column(
          crossAxisAlignment: "start",
          children: [
            Text(
              text: data.product.name,
              style: {
                fontSize: 24.0,
                fontWeight: "bold"
              }
            ),
            SizedBox(
              height: 8.0
            ),
            Text(
              text: [data.product.price, "원"],
              style: {
                fontSize: 20.0,
                color: 0xFF2196F3,
                fontWeight: "bold"
              }
            ),
            SizedBox(
              height: 16.0
            ),
            Container(
              padding: [12.0, 4.0, 12.0, 4.0],
              color: switch data.product.inStock {
                true: 0xFF4CAF50,
                false: 0xFFFF5722,
              },
              child: Text(
                text: switch data.product.inStock {
                  true: "재고 있음",
                  false: "품절",
                },
                style: {
                  color: 0xFFFFFFFF
                }
              )
            ),
            SizedBox(
              height: 16.0
            ),
            Text(
              text: data.product.description,
              style: {
                fontSize: 15.0,
                color: 0xFF616161
              }
            ),
            SizedBox(
              height: 24.0
            ),
            Row(
              mainAxisAlignment: "center",
              children: [
                ElevatedButton(
                  onPressed: event "quantity.decrease" {},
                  child: Text(
                    text: "-"
                  )
                ),
                Padding(
                  padding: [24.0, 0.0, 24.0, 0.0],
                  child: Text(
                    text: state.quantity,
                    style: {
                      fontSize: 20.0,
                      fontWeight: "bold"
                    }
                  )
                ),
                ElevatedButton(
                  onPressed: event "quantity.increase" {},
                  child: Text(
                    text: "+"
                  )
                )
              ]
            ),
            SizedBox(
              height: 24.0
            ),
            ElevatedButton(
              onPressed: event "addToCart" { id: data.product.id },
              child: Text(
                text: "장바구니에 담기"
              )
            )
          ]
        )
      )
    ]
  )
);

widget cart = Column(
  children: [
    Container(
      padding: [16.0],
      color: 0xFF2196F3,
      child: Text(
        text: "장바구니",
        style: {
          fontSize: 20.0,
          fontWeight: "bold",
          color: 0xFFFFFFFF
        }
      )
    ),
    Expanded(
      child: ListView(
        padding: [8.0],
        children: [
          ...for cartItem in data.cart.items:
            Card(
              margin: [0.0, 4.0, 0.0, 4.0],
              child: ListTile(
                title: Text(
                  text: cartItem.name
                ),
                subtitle: Text(
                  text: [cartItem.price, "원 × ", cartItem.quantity]
                ),
                trailing: Row(
                  mainAxisSize: "min",
                  children: [
                    GestureDetector(
                      onTap: event "cart.decrease" { id: cartItem.id },
                      child: Icon(
                        iconData: {
                          icon: 0x0000E4F7,
                          fontFamily: "MaterialIcons"
                        },
                        color: 0xFF757575
                      )
                    ),
                    Padding(
                      padding: [8.0, 0.0, 8.0, 0.0],
                      child: Text(
                        text: cartItem.quantity,
                        style: {
                          fontSize: 16.0,
                          fontWeight: "bold"
                        }
                      )
                    ),
                    GestureDetector(
                      onTap: event "cart.increase" { id: cartItem.id },
                      child: Icon(
                        iconData: {
                          icon: 0x0000E047,
                          fontFamily: "MaterialIcons"
                        },
                        color: 0xFF2196F3
                      )
                    )
                  ]
                )
              )
            )
        ]
      )
    ),
    Container(
      padding: [16.0],
      color: 0xFFF5F5F5,
      child: Column(
        children: [
          Row(
            mainAxisAlignment: "spaceBetween",
            children: [
              Text(
                text: "총 금액",
                style: {
                  fontSize: 18.0,
                  fontWeight: "bold"
                }
              ),
              Text(
                text: [data.cart.totalPrice, "원"],
                style: {
                  fontSize: 20.0,
                  color: 0xFF2196F3,
                  fontWeight: "bold"
                }
              )
            ]
          ),
          SizedBox(
            height: 12.0
          ),
          ElevatedButton(
            onPressed: event "checkout" {},
            child: Text(
              text: ["주문하기 (", data.cart.itemCount, "개)"]
            )
          )
        ]
      )
    )
  ]
);

