                            ),
                            SizedBox(
                              height: 4.0
                            ),
                            Container(
                              padding: [8.0, 2.0, 8.0, 2.0],
                              color: switch item.inStock {
                                true: 0xFF4CAF50,
                                false: 0xFFFF5722,
                              },
                              child: Text(
                                text: switch item.inStock {
                                  true: "재고 있음",
                                  false: "품절",
                                },
                                style: {
                                  color: 0xFFFFFFFF,
                                  fontSize: 12.0
                                }
                              )
