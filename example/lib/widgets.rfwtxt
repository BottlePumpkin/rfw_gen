widget settingsToggle { darkMode: false, notifications: true } = Container(
  padding: [20.0],
  child: Column(
    children: [
      Text(
        text: "Settings"
      ),
      SizedBox(
        height: 20.0
      ),
      GestureDetector(
        onTap: set state.darkMode = true,
        onDoubleTap: set state.darkMode = false,
        child: Container(
          padding: [16.0, 12.0, 16.0, 12.0],
          color: switch state.darkMode {
            true: 0xFF424242,
            false: 0xFFF5F5F5,
          },
          child: Row(
            children: [
              Text(
                text: "Dark Mode"
              ),
              SizedBox(
                width: 12.0
              ),
              switch state.darkMode {
                true: Text(
                  text: "ON"
                ),
                false: Text(
                  text: "OFF"
                ),
              }
            ]
          )
        )
      ),
      SizedBox(
        height: 12.0
      ),
      GestureDetector(
        onTap: set state.notifications = false,
        onDoubleTap: set state.notifications = true,
        child: Container(
          padding: [16.0, 12.0, 16.0, 12.0],
          color: switch state.notifications {
            true: 0xFFE8F5E9,
            false: 0xFFFCE4EC,
          },
          child: Row(
            children: [
              Text(
                text: "Notifications"
              ),
              SizedBox(
                width: 12.0
              ),
              switch state.notifications {
                true: Text(
                  text: "ON"
                ),
                false: Text(
                  text: "OFF"
                ),
              }
            ]
          )
        )
      ),
      SizedBox(
        height: 20.0
      ),
      GestureDetector(
        onTap: event "settings.save" { darkMode: state.darkMode, notifications: state.notifications },
        child: Container(
          padding: [24.0, 12.0, 24.0, 12.0],
          color: 0xFF1976D2,
          child: Center(
            child: Text(
              text: "Save Settings"
            )
          )
        )
      )
    ]
  )
);

