            color: 0xFFF5F5F5,
            child: Center(
              child: Text(
                text: state.count
              )
            )
          ),
          SizedBox(
            width: 24.0
          ),
          GestureDetector(
            onTap: event "counter.increment" {},
            child: Container(
              width: 48.0,
              height: 48.0,
              color: 0xFF66BB6A,
              child: Center(
                child: Text(
                  text: "+"
                )
              )
            )
          )
        ]
      )
    ]
  )
);
