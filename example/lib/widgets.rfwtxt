widget tabSelector { activeTab: 0x00000000 } = Column(
  children: [
    Row(
      mainAxisAlignment: "spaceEvenly",
      children: [
        GestureDetector(
          onTap: set state.activeTab = 0x00000000,
          child: Container(
            padding: [20.0, 12.0, 20.0, 12.0],
            color: switch state.activeTab {
              0x00000000: 0xFF1976D2,
              default: 0xFFBBDEFB,
            },
            child: Text(
              text: "Home"
            )
          )
        ),
        GestureDetector(
          onTap: set state.activeTab = 0x00000001,
          child: Container(
            padding: [20.0, 12.0, 20.0, 12.0],
            color: switch state.activeTab {
              0x00000001: 0xFF1976D2,
              default: 0xFFBBDEFB,
            },
            child: Text(
              text: "Search"
            )
          )
        ),
        GestureDetector(
          onTap: set state.activeTab = 0x00000002,
          child: Container(
            padding: [20.0, 12.0, 20.0, 12.0],
            color: switch state.activeTab {
              0x00000002: 0xFF1976D2,
              default: 0xFFBBDEFB,
            },
            child: Text(
              text: "Settings"
            )
          )
        )
      ]
    ),
    SizedBox(
      height: 16.0
    ),
    switch state.activeTab {
      0x00000000: Center(
        child: Text(
          text: "Home Content"
        )
      ),
      0x00000001: Center(
        child: Text(
          text: "Search Content"
        )
      ),
      0x00000002: Center(
        child: Text(
          text: "Settings Content"
        )
      ),
    }
  ]
);

