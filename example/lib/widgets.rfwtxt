    padding: [32.0, 16.0, 32.0, 16.0],
    color: switch state.pressed {
      true: 0xFF1565C0,
      false: 0xFF42A5F5,
    },
    child: Center(
      child: switch state.pressed {
        true: Text(
          text: "Pressing..."
        ),
        false: Text(
          text: "Press Me"
        ),
      }
    )
  )
);

